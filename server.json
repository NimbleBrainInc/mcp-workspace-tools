{
  "$schema": "https://schemas.nimblebrain.ai/v1/nimblebrain-server.schema.json",
  "name": "ai.nimblebrain/workspace-tools",
  "description": "Git-backed workspace tools for AI agents: file ops, commits, search, and skill validation",
  "version": "0.1.0",
  "title": "Workspace Tools MCP Server",
  "repository": {
    "url": "https://github.com/NimbleBrainInc/mcp-workspace-tools",
    "source": "https://github.com/NimbleBrainInc/mcp-workspace-tools"
  },
  "_meta": {
    "ai.nimblebrain/v1": {
      "runtime": "python:3.13",
      "capabilities": {
        "tools": true,
        "resources": true,
        "prompts": false
      },
      "display": {
        "category": "developer-tools",
        "tags": [
          "workspace",
          "git",
          "files",
          "search",
          "skills"
        ]
      },
      "deployment": {
        "protocol": "http",
        "port": 8000,
        "mcpPath": "/mcp"
      },
      "container": {
        "healthCheck": {
          "path": "/health",
          "port": 8000
        }
      },
      "resources": {
        "limits": {
          "memory": "512Mi",
          "cpu": "1000m"
        },
        "requests": {
          "memory": "256Mi",
          "cpu": "250m"
        }
      },
      "scaling": {
        "minReplicas": 1,
        "maxReplicas": 3
      }
    }
  }
}
